# ============================================================================
# ATS Resume Checker — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================================

# ── Google Gemini API ───────────────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Application Settings ───────────────────────────────────────────────────
# Backend server port
BACKEND_PORT=8000

# Frontend dev server URL (used for CORS)
FRONTEND_URL=http://localhost:5173

# ── File Storage ────────────────────────────────────────────────────────────
# Directory for uploaded resumes (relative to backend/)
UPLOAD_DIR=uploads

# Directory for generated resumes (relative to backend/)
GENERATED_DIR=generated
