# ============================================================================
# ATS Resume Checker — .gitignore
# ============================================================================

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
venv/
env/
.venv/

# ── Environment ─────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
frontend/dist/

# ── Uploads & Generated Files ───────────────────────────────────────────────
uploads/
generated/
.server.pid
*.aux
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# ── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
